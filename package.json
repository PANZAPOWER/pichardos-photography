{
  "name": "pichardos-photography",
  "version": "1.0.0",
  "description": "Pichardo's Photography — Elite Photography Website",
  "scripts": {
    "dev": "eleventy --serve",
    "build": "eleventy",
    "serve": "node scripts/serve.js",
    "deploy": "eleventy && wrangler pages deploy _site --project-name=pichardos-photography --branch=main --commit-dirty=true",
    "clean": "rimraf _site",
    "validate": "node scripts/validate-jsonld.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "rimraf": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
