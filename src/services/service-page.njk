---
layout: layouts/base.njk
pagination:
  data: services
  size: 1
  alias: svc
permalink: /services/{{ svc.slug }}/
eleventyComputed:
  title: "{{ svc.title }} in Texas | Pichardo's Photography"
  description: "{{ svc.short }} Serving Dallas, Fort Worth, Houston, Austin and all of Texas."
  ogImage: "{{ svc.heroImage }}"
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ svc.title }}",
  "description": "{{ svc.intro }}",
  "provider": {
    "@type": "LocalBusiness",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "areaServed": [{% for area in svc.areas %}"{{ area }}, TX"{% if not loop.last %},{% endif %}{% endfor %}],
  "url": "{{ site.url }}/services/{{ svc.slug }}/"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{% for faq in svc.faqs %}{
    "@type": "Question",
    "name": "{{ faq.q }}",
    "acceptedAnswer": { "@type": "Answer", "text": "{{ faq.a }}" }
  }{% if not loop.last %},{% endif %}{% endfor %}]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ site.url }}/"},
    {"@type":"ListItem","position":2,"name":"Services","item":"{{ site.url }}/services/"},
    {"@type":"ListItem","position":3,"name":"{{ svc.title }}","item":"{{ site.url }}/services/{{ svc.slug }}/"}
  ]
}
</script>
{% endblock %}

<!-- Page Hero -->
<section class="hero" style="min-height:70vh;">
  <div class="hero-bg">
    {% pic svc.heroImage, svc.title, { class: "hero-bg-img", widths: [1600], sizes: "100vw", loading: "eager", fetchpriority: "high", style: "object-position: center 30%" } %}
  </div>
  <div class="hero-content">
    <nav class="breadcrumb animate-up" aria-label="Breadcrumb">
      <a href="/">Home</a> / <a href="/services/">Services</a> / <span>{{ svc.title }}</span>
    </nav>
    <span style="font-size:3rem;display:block;margin-bottom:0.5rem;" class="animate-up delay-1">{{ svc.icon }}</span>
    <h1 class="animate-up delay-1" style="font-family:var(--font-serif);">{{ svc.title }}</h1>
    <p class="hero-tagline animate-up delay-2">{{ svc.short }}</p>
    <div class="hero-ctas animate-up delay-3">
      <a href="/contact/" class="btn btn-gold">Book This Session</a>
      <a href="/gallery/" class="btn btn-outline">View Gallery</a>
    </div>
  </div>
</section>

<!-- 40-word AEO Answer -->
<section style="background:var(--dark-mid);padding:2.5rem 0;">
  <div class="container">
    <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:var(--cream);max-width:800px;margin:0 auto;text-align:center;">
      "{{ svc.quote }}"
    </p>
  </div>
</section>

<!-- Intro -->
<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;">
      <div class="reveal">
        <span class="eyebrow">About This Service</span>
        <h2>{{ svc.title }}</h2>
        <div class="gold-line"></div>
        <p style="margin-bottom:2rem;">{{ svc.intro }}</p>
        <a href="/contact/" class="btn btn-gold">Book Your {{ svc.title }}</a>
      </div>
      <div class="reveal" style="animation-delay:0.15s;">
        <span class="eyebrow">What's Covered</span>
        <h3 style="margin-bottom:1.25rem;">Everything Included</h3>
        <ul style="list-style:none;">
          {% for item in svc.covers %}
          <li style="padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:0.75rem;font-size:0.92rem;color:var(--text-muted);">
            <span style="color:var(--gold);font-size:0.65rem;">◆</span> {{ item }}
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Process -->
<section class="section" style="background:var(--dark-mid);">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">How It Works</span>
      <h2>Our 3-Step Process</h2>
      <div class="gold-line center"></div>
    </div>
    <div class="grid-3 reveal">
      {% for step in svc.process %}
      <div style="text-align:center;padding:2rem;">
        <div style="width:60px;height:60px;border-radius:50%;border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-family:var(--font-serif);font-size:1.5rem;color:var(--gold);">{{ loop.index }}</div>
        <h4 style="margin-bottom:0.5rem;">{{ step.step }}</h4>
        <p style="font-size:0.88rem;color:var(--text-muted);">{{ step.detail }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Gallery Sample -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Real Sessions</span>
      <h2>{{ svc.title }} Portfolio</h2>
      <div class="gold-line center"></div>
    </div>
    <div class="gallery-masonry reveal">
      {% set galleryKey = svc.slug | replace("-photography","") | replace("quinceanera","xv") | replace("sweet-16","sweet16") | replace("prom","prom") | replace("graduation","graduation") | replace("portrait","portraits") | replace("dance","dance") | replace("sports","sports") | replace("professional-commercial","beautician") %}
      {% if galleryImages[galleryKey] %}
        {% for img in galleryImages[galleryKey] %}
        <div class="gal-item">
          {% pic img, svc.title + " photography by Pichardo's", { widths: [500], sizes: "(max-width: 768px) 50vw, 25vw", lightbox: true } %}
          <div class="gal-overlay"><span>⊕</span></div>
        </div>
        {% endfor %}
      {% else %}
        {% for cat, imgs in galleryImages %}{% for img in imgs | slice(0,3) %}
        <div class="gal-item">
          {% pic img, svc.title + " photography", { widths: [500], sizes: "(max-width: 768px) 50vw, 25vw", lightbox: true } %}
          <div class="gal-overlay"><span>⊕</span></div>
        </div>
        {% endfor %}{% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<!-- FAQs -->
<section class="section" style="background:var(--dark-mid);">
  <div class="container">
    <div style="max-width:720px;margin:0 auto;">
      <div class="section-header text-left reveal" style="text-align:left;max-width:none;margin:0 0 2rem;">
        <span class="eyebrow">Common Questions</span>
        <h2>FAQs — {{ svc.title }}</h2>
        <div class="gold-line"></div>
      </div>
      {% for faq in svc.faqs %}
      <details class="reveal">
        <summary>{{ faq.q }}</summary>
        <p>{{ faq.a }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="banner">
  {% pic svc.heroImage, "", { class: "banner-bg", widths: [1400], sizes: "100vw", ariaHidden: true } %}
  <div class="banner-content container">
    <span class="eyebrow">Ready to Book?</span>
    <h2>Reserve Your {{ svc.title }} Session</h2>
    <p style="color:var(--text-muted);max-width:500px;margin:1rem auto 2rem;">Dates fill up quickly. Contact us now to check availability and get a custom quote.</p>
    <a href="/contact/" class="btn btn-gold">Book Now</a>
  </div>
</section>
