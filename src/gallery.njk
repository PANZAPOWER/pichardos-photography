---
layout: layouts/base.njk
title: "Gallery — Photography Portfolio"
description: "Browse Pichardo's Photography portfolio — quinceañeras, sweet 16, prom, graduation, portraits, sports, dance and more across Texas."
ogImage: /assets/img/gallery/xv/aleyah-xv-1.JPEG
permalink: /gallery/
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": "Pichardo's Photography Gallery",
  "url": "{{ site.url }}/gallery/",
  "description": "Photography portfolio by Miguel Pichardo — quinceañeras, prom, graduation, portraits, sports, dance, and events across Texas.",
  "author": { "@type": "Person", "name": "{{ site.owner }}" }
}
</script>
{% endblock %}

<section class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="container">
    <span class="eyebrow animate-up">The Portfolio</span>
    <h1 class="animate-up delay-1">Our Gallery</h1>
    <div class="gold-line center animate-up delay-2"></div>
    <p style="max-width:600px;margin:1rem auto 0;color:var(--text-muted);" class="animate-up delay-2">
      Every image here is a real moment from a real session — artistically edited and proudly presented.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">

    <!-- Category Nav -->
    <div class="gallery-filter-bar reveal">
      <button class="gf-btn active" onclick="filterGallery('all')">All</button>
      <button class="gf-btn" onclick="filterGallery('xv')">Quinceañera</button>
      <button class="gf-btn" onclick="filterGallery('sweet16')">Sweet 16</button>
      <button class="gf-btn" onclick="filterGallery('prom')">Prom</button>
      <button class="gf-btn" onclick="filterGallery('graduation')">Graduation</button>
      <button class="gf-btn" onclick="filterGallery('portraits')">Portraits</button>
      <button class="gf-btn" onclick="filterGallery('dance')">Dance</button>
      <button class="gf-btn" onclick="filterGallery('sports')">Sports</button>
      <button class="gf-btn" onclick="filterGallery('boxing')">Boxing</button>
      <button class="gf-btn" onclick="filterGallery('beautician')">Commercial</button>
      <button class="gf-btn" onclick="filterGallery('sessions')">Sessions</button>
    </div>

    <!-- Masonry Grid -->
    <div class="gallery-masonry" id="gallery-grid">
      {% for cat, imgs in galleryImages %}
        {% for img in imgs %}
        <div class="gal-item" data-cat="{{ cat }}">
          <img
            src="{{ img }}"
            alt="Photography by Pichardo's Photography — {{ cat }} session"
            loading="lazy"
            width="400"
            height="600"
            data-lightbox="{{ img }}"
          >
          <div class="gal-overlay"><span>⊕</span></div>
        </div>
        {% endfor %}
      {% endfor %}
    </div>

  </div>
</section>

<!-- CTA -->
<section class="banner">
  <img class="banner-bg" src="/assets/img/gallery/prom/prom-1.jpeg" alt="" loading="lazy" aria-hidden="true">
  <div class="banner-content container">
    <span class="eyebrow">Love What You See?</span>
    <h2>Book Your Session</h2>
    <p style="color:rgba(255,255,255,0.85);max-width:500px;margin:1rem auto 2rem;">These are your people's milestones waiting to happen. Reserve your date before it's gone.</p>
    <a href="/contact/" class="btn btn-gold">Contact Us Today</a>
  </div>
</section>
