══════════════════════════════════════════════ -->
<section class="section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">What We Capture</span>
      <h2>Photography for Life's Greatest Milestones</h2>
      <div class="gold-line center"></div>
      <p>From quinceañeras to championships, every moment deserves to be immortalized by someone who truly cares about the art.</p>
    </div>

    <div class="services-8-grid">
      {% for svc in services %}
      <div class="reveal" style="animation-delay:{{ loop.index0 * 0.07 }}s;">
        <a href="/services/{{ svc.slug }}/" class="service-card" style="display:block;">
          <img
            src="{{ svc.heroImage }}"
            alt="{{ svc.title }} by Pichardo's Photography"
            loading="lazy"
            width="400" height="533"
          >
          <div class="service-card-overlay">
            <span class="service-card-icon">{{ svc.icon }}</span>
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.short }}</p>
            <span class="service-card-link">Explore →</span>
          </div>
        </a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-4 reveal">
      <a href="/services/" class="btn btn-gold-outline">All Photography Services</a>
