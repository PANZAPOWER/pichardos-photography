---
layout: layouts/base.njk
title: "Dallas Texas Photography — Quinceañeras, Sweet 16, Prom, Graduation & Portraits"
description: "Pichardo's Photography — Dallas, TX's premier photographer for quinceañeras, sweet 16s, proms, graduations, portraits, sports & events across all of Texas. Capturing Moments • Creating Memories."
ogImage: /assets/img/gallery/xv/xv-1.jpeg
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "{{ site.url }}/#business",
  "name": "{{ site.name }}",
  "description": "{{ site.description }}",
  "url": "{{ site.url }}",
  "logo": "{{ site.url }}{{ site.logo }}",
  "image": ["{{ site.url }}/assets/img/gallery/xv/xv-1.jpeg","{{ site.url }}/assets/img/gallery/prom/prom-1.jpeg","{{ site.url }}/assets/img/gallery/graduation/graduate-1.jpeg"],
  "founder": {
    "@type": "Person",
    "name": "{{ site.owner }}"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ site.address.city }}",
    "addressRegion": "{{ site.address.state }}",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "32.7767",
    "longitude": "-96.7970"
  },
  "areaServed": [{% for area in areas %}"{{ area.city }}, TX"{% if not loop.last %},{% endif %}{% endfor %}],
  "sameAs": ["{{ site.social.instagram }}","{{ site.social.facebook }}"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Photography Services",
    "itemListElement": [{% for svc in services %}{
      "@type": "Offer",
      "name": "{{ svc.title }}",
      "description": "{{ svc.short }}",
      "url": "{{ site.url }}/services/{{ svc.slug }}/"
    }{% if not loop.last %},{% endif %}{% endfor %}]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": "{{ reviews | length }}"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ site.owner }}",
  "jobTitle": "Professional Photographer",
  "worksFor": { "@type": "Organization", "name": "{{ site.name }}" },
  "url": "{{ site.url }}/about/",
  "sameAs": ["{{ site.social.instagram }}","{{ site.social.facebook }}"]
}
</script>
{% endblock %}

<!-- ═══════════════════════════════════════════════
  HERO
═══════════════════════════════════════════════ -->
<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <img
      class="hero-bg-img"
      src="/assets/img/gallery/xv/xv-1.jpeg"
      alt="Elegant quinceañera portrait by Pichardo's Photography"
      width="1600" height="900"
      loading="eager"
      fetchpriority="high"
      data-images='["/assets/img/gallery/xv/xv-1.jpeg","/assets/img/gallery/prom/prom-1.jpeg","/assets/img/gallery/graduation/graduate-fab-yards-1.jpeg","/assets/img/gallery/portraits/portraits-1.jpeg","/assets/img/gallery/xv/aleyah-xv-1.jpeg"]'
    >
  </div>

  <div class="hero-content">
    <div class="hero-kicker">
      <span>Capturing Moments</span>
      <span>Creating Memories</span>
    </div>

    <h1 class="hero-title animate-up">Pichardo's</h1>
    <p class="hero-subtitle animate-up delay-1">Photography</p>

    <p class="hero-tagline animate-up delay-2">
      Every milestone deserves to be remembered exactly as it felt — beautiful, alive, and forever yours.
    </p>

    <div class="hero-ctas animate-up delay-3">
      <a href="/contact/" class="btn btn-gold">Book Your Session</a>
      <a href="/gallery/" class="btn btn-outline">View Gallery</a>
    </div>

    <div style="margin-top: 3rem; display: flex; gap: 2rem; flex-wrap: wrap;" class="animate-up delay-4">
      <div>
        <span style="font-family:var(--font-script);font-size:2.5rem;color:var(--gold);display:block;line-height:1;">500+</span>
        <span style="font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-muted);">Sessions Captured</span>
      </div>
      <div>
        <span style="font-family:var(--font-script);font-size:2.5rem;color:var(--gold);display:block;line-height:1;">9+</span>
        <span style="font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-muted);">Cities Served</span>
      </div>
      <div>
        <span style="font-family:var(--font-script);font-size:2.5rem;color:var(--gold);display:block;line-height:1;">100%</span>
        <span style="font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-muted);">5-Star Reviews</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  TRUST STRIP
═══════════════════════════════════════════════ -->
<div class="trust-strip">
  <div class="container">
    <div class="trust-items">
      <div class="trust-item"><span class="trust-icon">⭐</span> 5-Star Rated</div>
      <div class="trust-item"><span class="trust-icon">📍</span> All of Texas</div>
      <div class="trust-item"><span class="trust-icon">📸</span> 500+ Sessions</div>
      <div class="trust-item"><span class="trust-icon">💛</span> Bilingual (EN/ES)</div>
      <div class="trust-item"><span class="trust-icon">🎨</span> Signature Editing</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
  INTRO QUOTE
═══════════════════════════════════════════════ -->
<section class="section-sm" style="background: var(--dark-mid);">
  <div class="container">
    <div class="quote-block reveal">
      <span class="quote-mark">"</span>
      <blockquote>
        Your story deserves to be told with artistry, passion, and precision —
        because these moments never come twice.
      </blockquote>
      <cite>— Miguel Pichardo, Founder</cite>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  SERVICES
═══════════════════════════════════════════════ -->
<section class="section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">What We Capture</span>
      <h2>Photography for Life's Greatest Milestones</h2>
      <div class="gold-line center"></div>
      <p>From quinceañeras to championships, every event in your life deserves to be immortalized by someone who truly cares about the art.</p>
    </div>

    <div class="grid-3 grid-4" style="grid-template-columns: repeat(4, 1fr);">
      {% for svc in services %}
      <div class="reveal" style="animation-delay: {{ loop.index0 * 0.08 }}s">
        <a href="/services/{{ svc.slug }}/" class="service-card" style="display:block;">
          <img
            src="{{ svc.heroImage }}"
            alt="{{ svc.title }} by Pichardo's Photography"
            loading="lazy"
            width="400" height="533"
          >
          <div class="service-card-overlay">
            <span class="service-card-icon">{{ svc.icon }}</span>
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.short }}</p>
            <span class="service-card-link">View Service →</span>
          </div>
        </a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-4 reveal">
      <a href="/services/" class="btn btn-gold-outline">All Services</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  GALLERY PREVIEW
═══════════════════════════════════════════════ -->
<section class="section" style="background: var(--dark-mid); padding-top: 0;">
  <div style="max-width: 100%;">
    <div class="container section-sm">
      <div class="section-header reveal">
        <span class="eyebrow">The Work</span>
        <h2>A Glimpse Into Our Portfolio</h2>
        <div class="gold-line center"></div>
        <p>Real sessions. Real moments. Artistically elevated.</p>
      </div>
    </div>

    <div class="gallery-cats reveal">
      <a href="/gallery/xv/" class="gallery-cat" aria-label="View Quinceañera gallery">
        <img src="/assets/img/gallery/xv/xv-1.jpeg" alt="Quinceañera photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Quinceañeras</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
      <a href="/gallery/prom/" class="gallery-cat" aria-label="View Prom gallery">
        <img src="/assets/img/gallery/prom/prom-1.jpeg" alt="Prom photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Prom</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
      <a href="/gallery/graduation/" class="gallery-cat" aria-label="View Graduation gallery">
        <img src="/assets/img/gallery/graduation/graduate-1.jpeg" alt="Graduation photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Graduation</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
      <a href="/gallery/portraits/" class="gallery-cat" aria-label="View Portraits gallery">
        <img src="/assets/img/gallery/portraits/portraits-1.jpeg" alt="Portrait photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Portraits</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
      <a href="/gallery/dance/" class="gallery-cat" aria-label="View Dance gallery">
        <img src="/assets/img/gallery/dance/dance-1.jpeg" alt="Dance photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Dance</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
      <a href="/gallery/sports/" class="gallery-cat" aria-label="View Sports gallery">
        <img src="/assets/img/gallery/sports/littleleaguebaseball-1.jpeg" alt="Sports photography by Pichardo's" loading="lazy" width="600" height="600">
        <div class="gallery-cat-overlay">
          <h3 class="gallery-cat-title">Sports</h3>
          <span class="gallery-cat-count">View Gallery →</span>
        </div>
      </a>
    </div>

    <div class="container section-sm text-center">
      <a href="/gallery/" class="btn btn-gold">View Full Gallery</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  STATS
═══════════════════════════════════════════════ -->
<section class="section-sm">
  <div class="container">
    <div class="stats-grid reveal">
      <div class="stat-item">
        <span class="stat-number" data-count="500" data-suffix="+">500+</span>
        <span class="stat-label">Sessions Captured</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-count="9" data-suffix="+">9+</span>
        <span class="stat-label">Texas Cities Served</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-count="100" data-suffix="%">100%</span>
        <span class="stat-label">5-Star Reviews</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-count="8" data-suffix="+">8+</span>
        <span class="stat-label">Years of Experience</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  ABOUT SNIPPET
═══════════════════════════════════════════════ -->
<section class="section" style="background: var(--dark-mid);">
  <div class="container">
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
      <div class="reveal">
        <img
          src="/assets/img/gallery/boxing/boxing-1.jpeg"
          alt="Miguel Pichardo — professional photographer at work"
          loading="lazy"
          width="600"
          height="700"
          style="width:100%;height:500px;object-fit:cover;border-radius:var(--radius);box-shadow:var(--shadow-gold);"
        >
      </div>
      <div class="reveal" style="animation-delay:0.2s">
        <span class="eyebrow">The Photographer</span>
        <h2>Meet Miguel Pichardo</h2>
        <div class="gold-line"></div>
        <p style="margin-bottom:1.25rem;">
          Miguel Pichardo is a Texas-based photographer with a deep passion for visual storytelling. His lens doesn't just take pictures — it captures the emotion, the energy, and the essence of every milestone moment.
        </p>
        <p style="margin-bottom:1.25rem; color: var(--text-muted);">
          From the first butterfly of a quinceañera court to the proud tears of a graduation, Miguel brings an artist's eye and a family man's heart to every session. He serves communities across all of Texas, photographing the moments that matter most to Latino families and beyond.
        </p>
        <p style="margin-bottom:2rem; color: var(--text-muted);">
          Follow him on Instagram at <a href="{{ site.social.instagram }}" target="_blank">@Pichardos_photography</a> to see the latest sessions and behind-the-scenes moments.
        </p>
        <a href="/about/" class="btn btn-gold-outline">Learn More About Miguel</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  REVIEWS
═══════════════════════════════════════════════ -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Client Love</span>
      <h2>What Families Say About Us</h2>
      <div class="gold-line center"></div>
    </div>

    <div class="grid-3 reveal">
      {% for review in reviews | slice(0, 3) %}
      <div class="review-card">
        <div class="stars" aria-label="{{ review.rating }} out of 5 stars">
          {% for i in range(0, review.rating) %}<span aria-hidden="true">★</span>{% endfor %}
        </div>
        <p class="review-text">"{{ review.text }}"</p>
        <div class="review-author">
          <div class="review-avatar" aria-hidden="true">{{ review.name[0] }}</div>
          <div>
            <span class="review-name">{{ review.name }}</span>
            <span class="review-meta">{{ review.event }} · {{ review.city }}</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-4 reveal">
      <a href="/reviews/" class="btn btn-gold-outline">Read All Reviews</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  SERVICE AREAS
═══════════════════════════════════════════════ -->
<section class="section" style="background: var(--dark-mid);">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Where We Go</span>
      <h2>Serving All of Texas</h2>
      <div class="gold-line center"></div>
      <p>Based in Dallas, we travel throughout the Lone Star State to capture your most important moments. No celebration is too far.</p>
    </div>

    <div class="grid-3 reveal">
      {% for area in areas %}
      <a href="/service-areas/{{ area.slug }}/" class="area-card" style="display:block;">
        <div class="area-city">{{ area.city }}</div>
        <div class="area-state">Texas</div>
        <ul class="area-landmarks">
          {% for landmark in area.landmarks | slice(0, 3) %}
          <li>{{ landmark }}</li>
          {% endfor %}
        </ul>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
  CTA BANNER
═══════════════════════════════════════════════ -->
<section class="banner">
  <img class="banner-bg" src="/assets/img/gallery/xv/xv-22.jpeg" alt="" loading="lazy" aria-hidden="true">
  <div class="banner-content container">
    <div class="reveal">
      <span class="eyebrow">Ready to Book?</span>
      <h2>Your Moment Deserves to Last Forever</h2>
      <p style="color:var(--text-muted);max-width:560px;margin:1rem auto 2rem;font-size:1.05rem;">
        Dates fill up fast — especially for quinceañeras, proms, and graduation season. Reserve yours today.
      </p>
      <a href="/contact/" class="btn btn-gold" style="font-size:0.8rem;">Book Your Session Now</a>
    </div>
  </div>
</section>
