══════════════════════════════════════════════ -->
<section class="hero" aria-label="Hero" style="min-height:100vh;">
  <div class="hero-bg">
    <img
      class="hero-bg-img"
      src="/assets/img/gallery/xv/aleyah-xv-1.JPEG"
      alt="Elegant quinceañera portrait by Pichardo's Photography Dallas"
      width="1920" height="1080"
      loading="eager"
      fetchpriority="high"
      data-images='[
        "/assets/img/gallery/xv/aleyah-xv-1.JPEG",
        "/assets/img/gallery/prom/prom-10.JPEG",
        "/assets/img/gallery/graduation/graduate--10.JPEG",
        "/assets/img/gallery/portraits/portraits-108.JPEG",
        "/assets/img/gallery/sweet16/sweet16-125.JPEG",
        "/assets/img/gallery/sessions/dunne-1.JPEG",
        "/assets/img/gallery/boxing/boxing-1AD842F6-B47D-4303-8195-367FA3CCB100-2.JPEG"
      ]'
    >
  </div>

  <div class="hero-content">
    <div class="hero-kicker animate-up">
      <span>Est. Dallas, Texas</span>
      <span>Since {{ site.founded }}</span>
    </div>

    <h1 class="hero-title animate-up delay-1">Pichardo's</h1>
    <p class="hero-subtitle animate-up delay-2" style="font-size:0.78rem;letter-spacing:0.45em;margin-bottom:2rem;">Photography</p>

    <p class="hero-tagline animate-up delay-2">
      Every milestone deserves to be remembered exactly as it felt —
      beautiful, alive, and forever yours.
    </p>

    <div class="hero-ctas animate-up delay-3">
      <a href="/contact/" class="btn btn-gold">Book Your Session</a>
      <a href="/gallery/" class="btn btn-outline">View Portfolio</a>
    </div>

    <div style="margin-top:3.5rem;display:flex;gap:3rem;flex-wrap:wrap;" class="animate-up delay-4">
      <div>
        <span style="font-family:var(--font-script);font-size:2.8rem;color:var(--gold);display:block;line-height:1;">500+</span>
        <span style="font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.35);">Sessions</span>
      </div>
      <div>
        <span style="font-family:var(--font-script);font-size:2.8rem;color:var(--gold);display:block;line-height:1;">9</span>
        <span style="font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.35);">Texas Cities</span>
      </div>
      <div>
        <span style="font-family:var(--font-script);font-size:2.8rem;color:var(--gold);display:block;line-height:1;">100%</span>
        <span style="font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.35);">5-Star Reviews</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#services" class="scroll-indicator" aria-label="Scroll to services">
    <span class="scroll-indicator-label">Scroll</span>
    <span class="scroll-indicator-line"></span>
  </a>
</section>


