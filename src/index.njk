---
layout: layouts/base.njk
title: "Dallas Texas Photography — Quinceañeras, Sweet 16, Prom, Graduation & Portraits"
description: "Pichardo's Photography — Dallas, TX's premier photographer for quinceañeras, sweet 16s, proms, graduations, portraits, sports & events across all of Texas. Capturing Moments • Creating Memories."
ogImage: /assets/img/gallery/xv/aleyah-xv-1.JPEG
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "{{ site.url }}/#business",
  "name": "{{ site.name }}",
  "description": "{{ site.description }}",
  "url": "{{ site.url }}",
  "logo": "{{ site.url }}{{ site.logo }}",
  "image": ["{{ site.url }}/assets/img/gallery/xv/aleyah-xv-1.JPEG","{{ site.url }}/assets/img/gallery/prom/prom-10.JPEG","{{ site.url }}/assets/img/gallery/graduation/graduate--10.JPEG"],
  "founder": { "@type": "Person", "name": "{{ site.owner }}" },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ site.address.city }}",
    "addressRegion": "{{ site.address.state }}",
    "addressCountry": "US"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": "32.7767", "longitude": "-96.7970" },
  "areaServed": [{% for area in areas %}"{{ area.city }}, TX"{% if not loop.last %},{% endif %}{% endfor %}],
  "sameAs": ["{{ site.social.instagram }}","{{ site.social.facebook }}"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Photography Services",
    "itemListElement": [{% for svc in services %}{
      "@type": "Offer",
      "name": "{{ svc.title }}",
      "description": "{{ svc.short }}",
      "url": "{{ site.url }}/services/{{ svc.slug }}/"
    }{% if not loop.last %},{% endif %}{% endfor %}]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": "{{ reviews | length }}"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ site.owner }}",
  "jobTitle": "Professional Photographer",
  "worksFor": { "@type": "Organization", "name": "{{ site.name }}" },
  "url": "{{ site.url }}/about/",
  "sameAs": ["{{ site.social.instagram }}","{{ site.social.facebook }}"]
}
</script>
{% endblock %}


<!-- ══════════════════════════════════════════════
