---
layout: layouts/base.njk
title: "FAQ — Photography Questions Answered | Pichardo's Photography"
description: "Frequently asked questions about booking, pricing, delivery, and photography sessions with Pichardo's Photography in Texas."
permalink: /faq/
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{% for cat in faqs %}{% for faq in cat.questions %}{
    "@type": "Question",
    "name": "{{ faq.q }}",
    "acceptedAnswer": { "@type": "Answer", "text": "{{ faq.a }}" }
  }{% if not loop.last or not faqs.last %},{% endif %}{% endfor %}{% if not loop.last %},{% endif %}{% endfor %}]
}
</script>
{% endblock %}

<section class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="container">
    <span class="eyebrow animate-up">Got Questions?</span>
    <h1 class="animate-up delay-1">Frequently Asked Questions</h1>
    <div class="gold-line center animate-up delay-2"></div>
    <p style="max-width:560px;margin:1rem auto 0;color:var(--text-muted);" class="animate-up delay-2">
      Everything you need to know about booking, sessions, pricing, and delivery — answered here.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="max-width:800px;margin:0 auto;">
      {% for cat in faqs %}
      <div class="faq-category reveal" style="margin-bottom:3rem;">
        <h3>{{ cat.category }}</h3>
        {% for faq in cat.questions %}
        <details>
          <summary>{{ faq.q }}</summary>
          <p>{{ faq.a }}</p>
        </details>
        {% endfor %}
      </div>
      {% endfor %}

      <div class="text-center reveal" style="margin-top:3rem;padding:2.5rem;background:var(--dark-card);border:1px solid rgba(201,168,76,0.15);border-radius:var(--radius);">
        <h3 style="margin-bottom:0.75rem;">Still Have Questions?</h3>
        <p style="color:var(--text-muted);margin-bottom:1.5rem;">We're happy to answer anything not covered here. Reach out directly or use our chat widget.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/contact/" class="btn btn-gold">Contact Us</a>
          <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" class="btn btn-gold-outline">DM on Instagram</a>
        </div>
      </div>
    </div>
  </div>
</section>
