<header class="site-header" id="site-header" role="banner">
  <nav class="nav-wrap" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Pichardo's Photography — Home">
      {% pic "/assets/img/logo/logo-1.jpg", "Miguel Pichardo's Photography logo", { class: "nav-logo-img", widths: [300], sizes: "150px", loading: "eager" } %}
      <div class="nav-logo-text">
        <span class="script-name">Pichardo's</span>
        <span class="tagline-small">Photography</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <ul class="nav-links" id="nav-links" role="list">
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/services/" class="nav-link">Services</a></li>
      <li><a href="/gallery/" class="nav-link">Gallery</a></li>
      <li><a href="/about/" class="nav-link">About</a></li>
      <li><a href="/packages/" class="nav-link">Packages</a></li>
      <li><a href="/reviews/" class="nav-link">Reviews</a></li>
      <li><a href="/blog/" class="nav-link">Blog</a></li>
      <li><a href="/service-areas/" class="nav-link">Areas</a></li>
