# Cloudflare Pages cache rules.
# Everything revalidates so a deploy is always picked up immediately;
# content-hashed optimized images are cached long.

/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/img/opt/*
  Cache-Control: public, max-age=31536000, immutable
